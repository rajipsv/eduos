# Copy to .env and fill in values. Never commit .env.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT auth (Option A) — required together for server-side login on Vercel/Neon
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Optional token lifetimes (seconds)
# JWT_ACCESS_TTL_SEC=900
# JWT_REFRESH_TTL_SEC=2592000

# Optional server settings
PORT=8888
HOST=127.0.0.1
